# Copy to .env
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory

JWT_SECRET=change-me-to-a-long-random-string

# Nessus Professional integration
# Get API keys from Nessus UI → My Account → API Keys
NESSUS_URL=https://nessus:8834
NESSUS_ACCESS_KEY=
NESSUS_SECRET_KEY=
NESSUS_VERIFY_SSL=false

# Nessus container credentials (set before first start)
NESSUS_ACTIVATION_CODE=
NESSUS_ADMIN_USER=admin
NESSUS_ADMIN_PASS=admin1234!
